DISCORD_TOKEN=your-bot-token
# Optional: only needed if the bot ID cannot be derived from the token
# DISCORD_BOT_ID=123456789012345678

# Container runtime (used by docker-compose). Defaults: 1000 / 1000 / UTC.
# Set PUID/PGID to your host user so files in ./data are owned correctly.
PUID=1000
PGID=1000
TZ=UTC
