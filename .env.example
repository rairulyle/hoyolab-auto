DISCORD_TOKEN=your-bot-token
# Optional: only needed if the bot ID cannot be derived from the token
# DISCORD_BOT_ID=123456789012345678

# Optional: restrict the bot to specific servers (comma-separated guild IDs).
# When set, the bot only serves these guilds — it refuses commands elsewhere
# and automatically leaves any server not listed. Leave unset to serve every
# server it is invited to.
# GUILD_IDS=111111111111111111,222222222222222222

# Container user/group (used by docker-compose). Defaults: 1000 / 1000.
# Set PUID/PGID to your host user so files in ./data are owned correctly.
# Scheduling timezone is per-server via /config timezone, not a container setting.
PUID=1000
PGID=1000
